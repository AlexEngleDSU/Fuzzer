version: 2
builds: [] # Keep this empty, we are skipping builds!

# Tell GoReleaser to find the binaries you downloaded from the artifacts
# Note: You may need to adjust the path if the download-artifact step 
# creates nested folders.
archives:
  - format: tar.gz
    name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    files:
      - src: 'dist/fuzzer-*/*' # Adjust pattern to match your artifact structure
