version: 2
version: 2
builds: [] # Skip build, we are providing pre-compiled binaries

archives:
  - format: tar.gz
    format_overrides:
      - goos: windows
        format: zip
    name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    files:
      - src: 'dist/fuzzer-ubuntu-latest/fuzzer'
        goos: linux
      - src: 'dist/fuzzer-macos-latest/fuzzer'
        goos: darwin
      - src: 'dist/fuzzer-windows-latest/fuzzer.exe'
        goos: windows
