version: 2
builds:
  - id: fuzzer
    skip: true

archives:
  - format: tar.gz
    name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    format_overrides:
      - goos: windows
        format: zip
    files:
      - src: 'dist/fuzzer-ubuntu-latest/fuzzer'
        dst: fuzzer
        goos: linux
      - src: 'dist/fuzzer-macos-latest/fuzzer'
        dst: fuzzer
        goos: darwin
      - src: 'dist/fuzzer-windows-latest/fuzzer.exe'
        dst: fuzzer.exe
        goos: windows
