version: 2
builds:
  - id: fuzzer
    skip: true

archives:
  # Linux Archive
  - id: linux-archive
    format: tar.gz
    name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    files:
      - src: 'dist/fuzzer-ubuntu-latest/fuzzer'
        dst: fuzzer
    # GoReleaser will naturally skip this if the file isn't present
    # for the current target OS build process.

  # macOS Archive
  - id: macos-archive
    format: tar.gz
    name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    files:
      - src: 'dist/fuzzer-macos-latest/fuzzer'
        dst: fuzzer

  # Windows Archive
  - id: windows-archive
    format: zip
    name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    files:
      - src: 'dist/fuzzer-windows-latest/fuzzer.exe'
        dst: fuzzer.exe
