version: 2
builds: []

archives:
  - format: tar.gz
    format_overrides:
      - goos: windows
        format: zip
    name_template: "{{ .ProjectName }}_{{ .Version }}_{{ .Os }}_{{ .Arch }}"
    files:
      - src: 'dist/fuzzer' # No longer needs the long path
        goos: linux
      - src: 'dist/fuzzer' # No longer needs the long path
        goos: darwin
      - src: 'dist/fuzzer.exe' # No longer needs the long path
        goos: windows
